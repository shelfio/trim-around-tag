{
  "name": "@shelf/trim-around-tag",
  "version": "3.0.0",
  "description": "Trims text to max length around custom HTML tag",
  "keywords": [],
  "repository": "shelfio/trim-around-tag",
  "license": "MIT",
  "author": {
    "name": "Vlad Holubiev",
    "email": "vlad@shelf.io",
    "url": "shelf.io"
  },
  "files": [
    "lib"
  ],
  "sideEffects": false,
  "type": "module",
  "exports": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "rm -rf lib/ && tsc",
    "coverage": "jest --coverage",
    "lint": "eslint . --fix",
    "lint:ci": "eslint .",
    "prepack": "yarn build",
    "test": "TZ=UTC jest src",
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch"
  },
  "prettier": "@shelf/prettier-config",
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.39.1",
    "@shelf/eslint-config": "5.3.4",
    "@shelf/prettier-config": "1.0.0",
    "@shelf/tsconfig": "0.1.0",
    "@swc/core": "1.15.3",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "@types/node": "20",
    "eslint": "10.2.0",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "jest-junit": "16.0.0",
    "lint-staged": "16.2.7",
    "prettier": "3.6.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{html,md,yml}": [
      "prettier --write"
    ],
    "*.{ts,js,json}": [
      "eslint --fix"
    ]
  }
}
